function updateShadow(){
  if(!shadowFig.sprite||shadowFig.lv!==currentLevel) return;
  if(observerLineCD>0) observerLineCD--;
  // Animated glitch + jitter while he's visible: swap among pre-baked torn frames and shudder
  // his position slightly. Cheap — frames are built once; this only swaps references.
  if(shadowFig.frames && shadowFig.sprite.material.opacity>0.02){
    shadowGlitchT--;
    if(shadowGlitchT<=0){
      shadowFig.sprite.material.map=shadowFig.frames[(Math.random()*shadowFig.frames.length)|0];
      shadowFig.sprite.material.needsUpdate=true;
      shadowGlitchT=3+((Math.random()*5)|0);
    }
    shadowFig.sprite.position.x=shadowFig.x+(Math.random()*2-1)*0.035;
    shadowFig.sprite.position.y=1.3+(Math.random()*2-1)*0.02;
  }
  const dx=shadowFig.x-cam.x,dz=shadowFig.z-cam.z;
  const dist=Math.hypot(dx,dz);
  const fwdX=Math.sin(cam.angle),fwdZ=Math.cos(cam.angle);
  const dot=(dx*fwdX+dz*fwdZ)/Math.max(0.1,dist);
  const looking=dot>0.75&&dist<14;
