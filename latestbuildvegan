// ─── LIGHT FLICKER (Claude's state machine) ──────────────
function updateLights(){
  const ld=levelData[currentLevel]; if(!ld) return;
  for(const f of ld.lightData){
    if(f.isFluorescent){
      // Claude's fluorescent state machine — the good one
      if(f.dead){ f.light.intensity=0; f.mesh.material.emissiveIntensity=0.04; continue; }
      f.t--;
      if(f.t<=0){
        if(f.state==='on'&&Math.random()<0.18){ f.state='flicker'; f.t=4+Math.floor(Math.random()*12); sfx.flick(); if(f.light) blackFlickerIn(f.light.position.x, f.light.position.z); }
        else if(f.state==='flicker'){ f.state='on'; f.t=120+Math.floor(Math.random()*240); }
        else f.t=120;
      }
      if(f.state==='flicker'){
        const on=Math.random()<0.45;
        f.light.intensity=on?f.baseI*1.4:0;
        f.mesh.material.emissiveIntensity=on?f.baseEm*1.6:0.1;
      } else {
        f.light.intensity=f.baseI;
        f.mesh.material.emissiveIntensity=f.baseEm;
      }
    } else {
      // Torch/lamp: organic flicker
      f.t--;
      if(f.t<=0){
        f.light.intensity=f.baseI*(0.72+Math.random()*0.55);
        f.t=4+Math.floor(Math.random()*18);
        if(f.flame){
          f.flame.material.opacity=0.8+Math.random()*0.2;
          f.flame.scale.set(0.16+Math.random()*0.08,(0.48+Math.random()*0.18),1);
        }
      }
    }
  }
}

