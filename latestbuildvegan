// The observer — reworked to be scary instead of comical. Near-black, armless, an elongated
// torso flaring into a floor-length smock (slaughterhouse silhouette — no cute legs), faintly
// asymmetric, heavily blurred, with very dim uneven eyes. Glitch is animated cheaply by
// pre-baking a few slice-torn variants once and swapping between them while he's visible.
function shadowSilhouette(){
  const c=document.createElement('canvas'); c.width=128; c.height=384; const x=c.getContext('2d');
  x.clearRect(0,0,128,384);
  x.filter='blur(5px)';
  x.fillStyle='rgba(4,4,8,0.94)';     // near-pure black
  // clear oval head, slightly off-centre/tilted
  x.beginPath(); x.ellipse(58,38,15,19,0.06,0,Math.PI*2); x.fill();
  // short thick neck
  x.fillRect(50,55,15,11);
  // BROAD shoulders -> the widest point (heavyset worker), tapering into a floor-length smock
  x.beginPath();
  x.moveTo(22,80);                          // left shoulder — wide
  x.quadraticCurveTo(58,62,98,82);          // broad shoulder line, faintly asymmetric
  x.lineTo(92,210);                         // right side down (narrower than shoulders)
  x.quadraticCurveTo(90,300,82,362);        // smock to floor
  x.lineTo(42,362);
  x.quadraticCurveTo(34,300,32,210);        // left side
  x.closePath(); x.fill();
  // ONE heavy arm hanging on the right, held a little away from the body so the blur keeps a gap
  x.beginPath();
  x.moveTo(94,86);
  x.quadraticCurveTo(112,98,110,160);       // upper arm out + down
  x.quadraticCurveTo(110,212,101,248);      // forearm past the hip
  x.lineTo(90,246);
  x.quadraticCurveTo(98,200,92,150);        // inner edge back up (gap from torso)
  x.quadraticCurveTo(90,108,94,86);
  x.closePath(); x.fill();
  x.beginPath(); x.ellipse(95,252,8,10,0,0,Math.PI*2); x.fill();  // heavy hand mass
  // very dim, uneven eyes — "were those eyes?" not a face
  x.filter='blur(2px)';
  x.fillStyle='rgba(150,28,28,0.32)';
  x.beginPath(); x.arc(52,36,2.7,0,Math.PI*2); x.fill();
  x.fillStyle='rgba(150,28,28,0.22)';
  x.beginPath(); x.arc(65,38,1.9,0,Math.PI*2); x.fill();          // lower, smaller, dimmer
  x.filter='none';
  // feather head-top and smock-bottom into nothing
  const g=x.createLinearGradient(0,0,0,384);
  g.addColorStop(0,'rgba(0,0,0,0)'); g.addColorStop(0.085,'rgba(0,0,0,1)');
  g.addColorStop(0.88,'rgba(0,0,0,1)'); g.addColorStop(1,'rgba(0,0,0,0)');
  x.globalCompositeOperation='destination-in'; x.fillStyle=g; x.fillRect(0,0,128,384);
  x.globalCompositeOperation='source-over';
  return c;
}
function makeShadowFrames(){
  const base=shadowSilhouette();
  const frames=[new THREE.CanvasTexture(base)]; // frame 0: least corrupted
  for(let f=0; f<4; f++){
    const c=document.createElement('canvas'); c.width=128; c.height=384; const x=c.getContext('2d');
    const amp=4+f*3; // later frames tear harder
    let y=0;
    while(y<384){
      const h=6+Math.random()*36;
      const dx=(Math.random()*2-1)*amp;
      x.drawImage(base, 0,y,128,h, dx,y,128,h);                 // displaced slice (datamosh)
      if(Math.random()<0.3){                                    // faint chromatic ghost
        x.globalAlpha=0.22; x.drawImage(base, 0,y,128,h, dx+(Math.random()*8-4),y,128,h); x.globalAlpha=1;
      }
      y+=h;
    }
    const t=new THREE.CanvasTexture(c); frames.push(t);
  }
  return frames;
}

