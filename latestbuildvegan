// ─── TORCHES FOR LAZY LEVELS ────────────────────────────
// When L2 or L3 is first built, torches need to be placed if buildLevel was called after placeTorches
// So we do a lazy-place on first visit
const torchesByLevel={1:false,2:false,3:false};
function ensureTorchesForLevel(lv){
  if(torchesByLevel[lv]) return;
  torchesByLevel[lv]=true;
  const map=MAPS[lv-1];
  const grp=levelGroups[lv]; if(!grp) return;
  const n=lv===1?2:lv===2?2:3;
  const cands=[];
  for(let z=4;z<GRID-4;z++) for(let x=4;x<GRID-4;x++){
    if(map[z*GRID+x]===0){ const d=Math.hypot(x-16,z-16); if(d>5) cands.push([x,z,d]); }
  }
  cands.sort((a,b)=>(b[2]+Math.random()*3)-(a[2]+Math.random()*3));
  const placed=[];
  for(const c of cands){
    if(placed.length>=n) break;
    if(placed.every(p=>Math.hypot(p[0]-c[0],p[1]-c[1])>5)) placed.push(c);
  }
  placed.forEach(([x,z])=>{
    const flameMat=new THREE.SpriteMaterial({map:torchFlameSprite(),transparent:true,depthWrite:false,opacity:0});
    const sprite=new THREE.Sprite(flameMat); sprite.scale.set(0.35,0.9,1);
    sprite.position.set(x+0.5,1.1,z+0.5); sprite.visible=false; grp.add(sprite);
    const light=new THREE.PointLight(0xff9020,0,5.5,1.8);
    light.position.set(x+0.5,1.4,z+0.5); grp.add(light);
    const halo=new THREE.Mesh(new THREE.SphereGeometry(0.45,12,8),
      new THREE.MeshBasicMaterial({color:0xff8010,transparent:true,opacity:0,depthWrite:false}));
    halo.position.set(x+0.5,1.2,z+0.5); halo.visible=false; grp.add(halo);
    allTorches.push({sprite,light,halo,collected:false,unlocked:false,baseY:1.1,phase:Math.random()*7,lv,x:x+0.5,z:z+0.5});
  });
}

// Reveal one hidden torch on the current level (called when player reads a wall text)
function unlockTorchOnLevel(lv){
  const hidden = allTorches.filter(t=> t.lv===lv && !t.unlocked && !t.collected);
  if(hidden.length===0) return false;
  const t = hidden[Math.floor(Math.random()*hidden.length)];
  t.unlocked = true;
  t.sprite.visible = true;
  t.sprite.material.opacity = 1;
  t.halo.visible = true;
  t.light.intensity = 2.2;
  whisperLine("a torch has appeared in the dark");
  return true;
}

let frameCount=0;
let last=performance.now();
