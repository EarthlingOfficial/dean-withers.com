    // ── IN-WORLD SECRET ROOM CONTENTS (panels on walls + wall TV) ──
    // chamber spans x:52..61, z:4..13. Place 5 glyph panels along the far/side walls.
    secretGlyphMeshes=[];
    const glyphSpots=[
      {x:53.0,z:4.15,ry:0},        // north wall
