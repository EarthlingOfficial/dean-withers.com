  }
  function placeDecal(tex,opts={}){
    if(!wallPositions.length) return null;
    for(let attempt=0;attempt<25;attempt++){
      const wp=wallPositions[Math.floor(Math.random()*wallPositions.length)];
      // Verify front face is in open corridor (not against another wall)
      const frontClear=!solidAt(map,wp.wx-wp.dx*2,wp.wz-wp.dz*2);
      if(!frontClear) continue;
      const w=Math.min(0.9, opts.w||0.85), h=opts.h||0.4;
      const geo=new THREE.PlaneGeometry(w,h);
      const mat=new THREE.MeshBasicMaterial({map:tex,transparent:true,depthWrite:false,opacity:opts.opacity||0.92});
      const m=new THREE.Mesh(geo,mat);
      m.position.set(
        wp.wx-wp.dx*0.502, opts.y||1.5,
        wp.wz-wp.dz*0.502
      );
      if(wp.dx===1) m.rotation.y=-Math.PI/2;
      else if(wp.dx===-1) m.rotation.y=Math.PI/2;
      else if(wp.dz===-1) m.rotation.y=Math.PI;
      grp.add(m);
      return {mesh:m,pos:m.position.clone()};
    }
    return null;
  }
  // Compute decal height from text length (longer text → taller decal, narrow width)
  function decalSizeFor(text, baseW){
    const len = text.length;
    const w = baseW || 0.88;
    let h;
    if(len <= 24) h = w * 0.45;
    else if(len <= 60) h = w * 0.65;
    else if(len <= 120) h = w * 0.95;
    else h = w * 1.25;
    return {w, h};
  }
  // Random subset selector — different walls each playthrough
  function pickSubset(arr, n){
    const copy = arr.slice();
    for(let i=copy.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [copy[i],copy[j]]=[copy[j],copy[i]]; }
    return copy.slice(0, Math.min(n, copy.length));
  }

  if(cfg.isHiero){
    // L1: hieroglyphs from the original pool + Stage 8 Architect lore
    const picked = pickSubset(cfg.wallTexts.concat(S8_WALL_L1), 20);
    picked.forEach((text,i)=>{
      const htex=hieroglyphTex(i*7+lv*13);
      const revealTex=writingTex(text,'glow',true);
      const sz=decalSizeFor(text);
      const result=placeDecal(htex,{w:sz.w, h:sz.h, y:1.4+(Math.random()-0.5)*0.4, opacity:0.9});
      if(result) hieroData.push({mesh:result.mesh,revealTex,baseTex:result.mesh.material.map,revealed:false,pos:result.pos,origText:text});
    });
  } else if(lv===2){
    // L2: blood-smeared readables — original pool + Stage 8 lore
    const picked = pickSubset(cfg.wallTexts.concat(S8_WALL_L2), 20);
    picked.forEach((text,i)=>{
      const smearTex=smearedTex(i*11+lv*23);
      const revealTex=writingTex(text,'scratch');
      const sz=decalSizeFor(text);
      const result=placeDecal(smearTex,{w:sz.w, h:sz.h, y:1.3+(Math.random()-0.5)*0.45, opacity:0.92});
      if(result) hieroData.push({mesh:result.mesh,revealTex,baseTex:result.mesh.material.map,revealed:false,pos:result.pos,origText:text});
    });
  } else {
    // L3: faded-wallpaper readables — original pool + Stage 8 lore
    const picked = pickSubset(cfg.wallTexts.concat(S8_WALL_L3), 22);
    picked.forEach((text,i)=>{
      const fade=fadedTex(i*13+lv*29);
      const style=['glow','typed','smeared'][i%3];
      const revealTex=writingTex(text,style);
      const sz=decalSizeFor(text);
      const result=placeDecal(fade,{w:sz.w, h:sz.h, y:1.3+(Math.random()-0.5)*0.45, opacity:0.88});
      if(result) hieroData.push({mesh:result.mesh,revealTex,baseTex:result.mesh.material.map,revealed:false,pos:result.pos,origText:text});
    });
  }

  // Character quotes — pick 5 random from pool of 10 per level visit
  const pickedQuotes = pickSubset(CHAR_QUOTES, 5);
  pickedQuotes.forEach((q)=>{
    const c=document.createElement('canvas'); c.width=512; c.height=512; const x=c.getContext('2d');
    x.clearRect(0,0,512,512);
    x.fillStyle='rgba(220,170,70,0.96)'; x.shadowColor='rgba(200,150,50,1)'; x.shadowBlur=12;
    x.font="italic 30px 'Cormorant Garamond',serif"; x.textAlign='center'; x.textBaseline='middle';
    const maxW = 460;
    const words=q.q.split(' '); const lines=[]; let line='';
    for(const w of words){ const t=line?line+' '+w:w; if(x.measureText(t).width>maxW&&line){lines.push(line);line=w;}else line=t; }
    if(line) lines.push(line);
    const lh=38, start=200-(lines.length-1)*lh/2;
    lines.forEach((l,k)=> x.fillText('"'+l+'"',256,start+k*lh));
    x.shadowBlur=0; x.font="bold 16px 'Space Mono',monospace"; x.fillStyle='rgba(180,140,60,0.85)';
    x.fillText('— '+q.who,256,440);
    const tex=new THREE.CanvasTexture(c);
    placeDecal(tex,{w:0.88, h:0.88, y:1.55, opacity:0.95});
  });

  // Iconography photos
  for(let i=0;i<12;i++) placeDecal(iconographyTex(i),{w:0.55,h:0.55,y:1.4+(Math.random()-0.5)*0.4,opacity:0.88});

  // Open cells cache
  const openCells=[];
  for(let z=2;z<GRID-2;z++) for(let x=2;x<GRID-2;x++) if(map[z*GRID+x]===0) openCells.push([x,z]);

  levelData[lv]={map,cfg,ceilH,lightData,hieroData,wallPositions,openCells,grp};
}

