function powerupTex(color){
  const c=document.createElement('canvas'); c.width=c.height=64; const x=c.getContext('2d');
  const hex='#'+color.toString(16).padStart(6,'0');
  const g=x.createRadialGradient(32,32,2,32,32,30); g.addColorStop(0,hex); g.addColorStop(0.5,hex+'aa'); g.addColorStop(1,hex+'00');
  x.fillStyle=g; x.beginPath(); x.arc(32,32,30,0,7); x.fill();
  x.fillStyle='rgba(255,255,255,0.9)'; x.font='28px serif'; x.textAlign='center'; x.textBaseline='middle'; x.fillText('✦',32,33);
  return new THREE.CanvasTexture(c);
}
function ensurePowerupsForLevel(lv){
  if(powerupsByLevel[lv]) return; powerupsByLevel[lv]=true;
  const map=MAPS[lv-1]; const grp=levelGroups[lv]; if(!grp) return;
  // gather candidate cells, spread out
  const cands=[];
  for(let z=4;z<GRID-4;z+=1) for(let x=4;x<GRID-4;x+=1){ if(map[z*GRID+x]===0) cands.push([x,z]); }
  // pick ~4 well-separated spots per level
  const placed=[];
  for(let i=0;i<cands.length && placed.length<4;i++){
    const c=cands[(Math.random()*cands.length)|0];
    if(placed.every(p=>Math.hypot(p[0]-c[0],p[1]-c[1])>10)) placed.push(c);
  }
  placed.forEach((c,i)=>{
    const pu=POWERUPS[(i+lv)%POWERUPS.length];
    const mat=new THREE.SpriteMaterial({map:powerupTex(pu.color),transparent:true,depthWrite:false});
    const sprite=new THREE.Sprite(mat); sprite.scale.set(0.6,0.6,1); sprite.position.set(c[0]+0.5,1.2,c[1]+0.5); grp.add(sprite);
    const light=new THREE.PointLight(pu.color,0.8,4,2); light.position.set(c[0]+0.5,1.2,c[1]+0.5); grp.add(light);
    allPowerups.push({sprite,light,lv,x:c[0]+0.5,z:c[1]+0.5,collected:false,def:pu,phase:Math.random()*7});
  });
}
function updatePowerups(){
  const t=performance.now();
  for(const p of allPowerups){
    if(p.collected||p.lv!==currentLevel) continue;
    p.sprite.position.y=1.2+Math.sin(t*0.003+p.phase)*0.12;
    p.sprite.material.rotation+=0.02;
    const d=Math.hypot(p.x-cam.x,p.z-cam.z);
    if(d<0.9){
      p.collected=true; p.sprite.visible=false; p.light.intensity=0;
      applyPowerup(p.def); try{ sfx.torch&&sfx.torch(); }catch(e){}
    }
  }
}
function applyPowerup(def){
  if(def.key==='health'){ hp=Math.min(100,hp+35); }
  else if(def.key==='sanity'){ sanity=Math.min(100,sanity+40); }
  else if(def.key==='both'){ hp=Math.min(100,hp+20); sanity=Math.min(100,sanity+20); }
  else if(def.key==='speed'){ speedBoostUntil=performance.now()+12000; }
  else if(def.key==='invuln'){ invulnUntil=performance.now()+10000; }
