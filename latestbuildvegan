    composer.setPixelRatio(renderer.getPixelRatio());
    composer.setSize(innerWidth, innerHeight);
    if(!isMobile && SSAO_ENABLED){
      // SSAOPass renders the scene itself (beauty + AO), so it stands in for RenderPass on desktop.
      ssaoPass = new SSAOPass(scene, camera, innerWidth, innerHeight);
      ssaoPass.kernelRadius = 0.5;    // tuned for the ~1-unit grid scale
      ssaoPass.minDistance  = 0.0008;
      ssaoPass.maxDistance  = 0.06;
      composer.addPass(ssaoPass);
    } else {
      composer.addPass(new RenderPass(scene, camera));
    }
    bloomPass = new UnrealBloomPass(bloomRes(), BLOOM_STRENGTH, BLOOM_RADIUS, BLOOM_THRESHOLD);
    composer.addPass(bloomPass);
    composer.addPass(new OutputPass()); // ACES tone map + sRGB conversion, last in the chain
    usePost = true;
  }catch(err){
    console.warn('Post-processing failed to initialise — using direct render.', err);
    composer = null; usePost = false;
  }
}
