  NMAP.wallpaper=mkNormal(wallpaperTex(),0.8); NMAP.wallpaper.repeat.set(1,1.4);
}

// Writing texture — auto-sizes height to text length so decal can stay narrow
function writingTex(text,style,forHiero=false){
  // pre-measure to decide canvas aspect
  const isShort = text.length<=24;
  const isMedium = text.length<=60;
  const cw = 512;
  const ch = isShort ? 256 : isMedium ? 384 : 512;
  const c=document.createElement('canvas'); c.width=cw; c.height=ch; const x=c.getContext('2d');
  x.clearRect(0,0,cw,ch);
  if(forHiero||style==='glow'){ x.font="italic 44px 'Cormorant Garamond',serif"; x.fillStyle='rgba(210,170,70,0.96)'; x.shadowColor='rgba(200,150,50,0.6)'; x.shadowBlur=14; }
  else if(style==='scratch'){ x.font="38px 'Permanent Marker',sans-serif"; x.fillStyle='rgba(210,40,40,0.94)'; x.shadowColor='rgba(160,15,15,0.55)'; x.shadowBlur=4; }
  else if(style==='typed'){ x.font="30px 'Special Elite',monospace"; x.fillStyle='rgba(40,28,14,0.92)'; }
  else { x.font="36px 'Special Elite',monospace"; x.fillStyle='rgba(85,30,15,0.9)'; x.shadowColor='rgba(35,8,3,0.65)'; x.shadowBlur=6; }
  x.textAlign='center'; x.textBaseline='middle';
  const maxW = cw - 40;
  const words=text.split(' '); const lines=[]; let line='';
  for(const w of words){ const t=line?line+' '+w:w; if(x.measureText(t).width>maxW&&line){lines.push(line);line=w;}else line=t; }
  if(line) lines.push(line);
  const lh = parseInt(x.font, 10) * 1.15;
  const start = ch/2 - (lines.length-1)*lh/2;
  lines.forEach((l,i)=> x.fillText(l, cw/2, start+i*lh));
  return new THREE.CanvasTexture(c);
}

function hieroglyphTex(seed){
  const c=document.createElement('canvas'); c.width=512; c.height=256; const x=c.getContext('2d');
  x.fillStyle='rgba(45,32,15,0.9)'; x.fillRect(0,0,512,256);
  x.strokeStyle='rgba(180,140,60,0.4)'; x.lineWidth=2; x.strokeRect(4,4,504,248);
  const rng=(n)=>{ let s=seed+n; s=Math.sin(s)*43758.5453; return s-Math.floor(s); };
  const symbols=['|','—','△','○','□','⊕','⊗','☥','𓂀','𓆣','𓏏','𓅓'];
  x.fillStyle='rgba(190,145,55,0.75)'; x.font='26px serif'; x.textAlign='center'; x.textBaseline='middle';
  let px=40;
  for(let i=0;i<10;i++){
    const sym=symbols[Math.floor(rng(i*7)*symbols.length)];
    x.fillText(sym,px,80+(rng(i*3)-0.5)*40); px+=42+rng(i*5)*20;
    x.font='16px serif'; x.fillText(symbols[Math.floor(rng(i*11)*symbols.length)],px-20,140+rng(i*9)*30);
    x.font='26px serif';
  }
  return new THREE.CanvasTexture(c);
}

