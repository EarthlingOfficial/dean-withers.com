function blackStrike(){
  if(godMode || performance.now()<invulnUntil){ blackFig.hide(); stareFrames=0; blackCooldown=BLACK_LULL_FRAMES; return; }
  if(!blackStrikeReady || blackCooldown>0) return;  // hard-gate: no strike during the lull
  blackStrikeReady=false;
