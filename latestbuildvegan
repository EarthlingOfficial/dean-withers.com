function blackCellOpen(x,z){ return !solidAt(MAPS[currentLevel-1], x, z); }

// Live darkness probe: a cell is "dark" if no currently-lit light is close + bright.
function darknessAt(x,z){
  const ld=levelData[currentLevel]; if(!ld) return 1;
  let lit=0;
  for(const f of ld.lightData){
    if(!f.light) continue;
    const I=f.light.intensity; if(I<=0.05) continue;
    const lx=f.light.position.x, lz=f.light.position.z;
    const d2=(lx-x)*(lx-x)+(lz-z)*(lz-z);
    lit += I/(1+d2*0.6);
  }
  return 1/(1+lit); // ~1 = pitch dark, ->0 = brightly lit
}
// Throttled cache: the player-position darkness only needs recomputing a few times a second.
// Saves looping over every light on every frame for the hot-path figure checks.
let _darkCacheVal=1, _darkCacheT=0;
function darknessAtPlayerCached(){
  _darkCacheT--;
  if(_darkCacheT<=0){ _darkCacheVal=darknessAt(cam.x,cam.z); _darkCacheT=4; } // recompute every 4th frame
  return _darkCacheVal;
}
// THE effect: identical to the backrooms strobe (one subtle crack + a short white-flash burst
// that terminates itself). Reused verbatim. No tape-rewind, no extra layers.
function quickStrobe(){
  const el=$('strobe'); if(!el) return;
  sfx.strobeHit();
