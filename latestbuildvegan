    if(currentLevel===3&&!strobeActive){ nextStrobe--; if(nextStrobe<=0) doStrobe(); }

    if(Math.random()<0.002){
      const fl=$('flicker'); fl.style.opacity=String(0.45+Math.random()*0.3);
      setTimeout(()=>fl.style.opacity='0',40+Math.random()*100);
    }
    // After sanity is gone: the same crack-and-flash recurs more often. No new look or sound.
    if(spiralActive){ spiralFlashT--; if(spiralFlashT<=0){ quickStrobe(); spiralFlashT=20*60; } } // once every 20s, nothing more

    ensureTorchesForLevel(currentLevel);
  }

  camera.position.set(cam.x,cam.y,cam.z);
  const ld2=Math.cos(cam.pitch);
  camera.lookAt(cam.x+Math.sin(cam.angle)*ld2,cam.y+Math.sin(cam.pitch),cam.z+Math.cos(cam.angle)*ld2);
  // Per-level pipeline: only Level III runs the composer (ACES + bloom). Levels I & II render
  // directly with NO tone mapping — pixel-for-pixel the original look (no bloom, original brightness).
  if(usePost && composer && currentLevel===3){
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    try{ composer.render(); }
    catch(err){ console.warn('Composer render failed — falling back to direct render.', err); usePost=false; renderer.toneMapping=THREE.NoToneMapping; renderer.render(scene,camera); }
  } else {
    renderer.toneMapping = THREE.NoToneMapping;
    renderer.render(scene,camera);
  }
}
loop();

// ─── MEAT-CHAT FEED (scrolling comment overlay) ──────────
// Self-contained, driven by setTimeout (NOT the render loop) so it costs nothing per WebGL frame.
// Gated to phase==='play'; idles silently on menus/story/ending. pointer-events:none -> never blocks taps.
(function(){
  const feed=document.getElementById('meatchat');
  if(!feed) return;
  if(isTouch) feed.classList.add('mc-mobile');
  const CAP=4; // max comments on screen; extras scroll off the top
  const CHAT_SANITY_DRAIN=0.75; // gentle, tunable. ~0.5–1 is the readable range; raise to pressure harder.
  let busy=false, pending=null;
  const reduce=matchMedia('(prefers-reduced-motion: reduce)').matches;
  const rnd=(a,b)=>a+Math.random()*(b-a);
  const pick=a=>a[(Math.random()*a.length)|0];
  function redepth(){
    const rows=[...feed.querySelectorAll('.mc-row:not(.mc-out)')]; const n=rows.length;
    rows.forEach((r,i)=>{ const d=n-1-i; r.style.opacity=Math.max(0.18,1-d*0.26).toFixed(2); });
  }
  function addRow(){
    const row=document.createElement('div'); row.className='mc-row';
    const h=document.createElement('span'); h.className='mc-h'; h.textContent=pick(MEAT_HANDLES);
    const c=document.createElement('span'); c.className='mc-c'; c.textContent=pick(MEAT_COMMENTS);
    row.appendChild(h); row.appendChild(c); feed.appendChild(row);
    // Each comment chips a little sanity — gentle, cumulative, never touches health.
    if(phase==='play'){ if(!godMode){ sanity=Math.max(0,sanity-CHAT_SANITY_DRAIN); if(sanity<=0 && !sanityZeroed) triggerSanityBreak(); } updateHUD(); }
    if(reduce) row.classList.add('mc-in'); else requestAnimationFrame(()=>row.classList.add('mc-in'));
    redepth();
    const rows=feed.querySelectorAll('.mc-row:not(.mc-out)');
    if(rows.length>CAP) removeTop(rows[0]);
  }
  function removeTop(row){
    row.classList.add('mc-out'); row.classList.remove('mc-in');
    setTimeout(()=>{ row.remove(); redepth(); }, reduce?0:380);
  }
  function clearFeed(){ feed.classList.remove('mc-hide'); feed.style.opacity=''; feed.innerHTML=''; }
  function fadeClear(cb){ feed.classList.add('mc-hide'); setTimeout(()=>{ clearFeed(); cb&&cb(); }, reduce?0:520); }
  function runBurst(){
    if(phase!=='play'){ clearFeed(); busy=false; pending=setTimeout(schedule,1500); return; }
    busy=true;
    const n=2+((Math.random()*4)|0); // burst of 2..5 comments
    let i=0;
    const step=()=>{
      if(phase!=='play'){ fadeClear(()=>{ busy=false; schedule(); }); return; }
      addRow(); i++;
      if(i<n) pending=setTimeout(step,rnd(1000,1600));
      else pending=setTimeout(()=>fadeClear(()=>{ busy=false; schedule(); }),1700);
    };
    step();
  }
  function schedule(){ pending=setTimeout(runBurst, rnd(6000,13000)); } // quiet gap -> keeps it from hogging the screen
  schedule();
})();

addEventListener('resize',()=>{
  camera.aspect=innerWidth/innerHeight; camera.updateProjectionMatrix();
  renderer.setSize(innerWidth,innerHeight);
  if(composer) composer.setSize(innerWidth,innerHeight);
  if(bloomPass) bloomPass.setSize(bloomRes().x, bloomRes().y);
  if(ssaoPass) ssaoPass.setSize(innerWidth,innerHeight);
});
</script>
</body>
