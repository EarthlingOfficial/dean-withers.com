const BLACK_MAX_OPACITY=0.36;        // even more transparent — pure dread, never resolves
const STRIKE_FRAC=0.20;              // 20% off the relevant meter per strike (5 hits to empty)
const STRIKE_RANGE=1.1;              // ~1 foot
