// ─── MOVEMENT ───────────────────────────────────────────
function move(){
  if(phase!=='play') return;
  const map=MAPS[currentLevel-1];
  let fwd=0,str=0,turn=0;
  if(keys.w) fwd+=1; if(keys.s) fwd-=1;
  if(keys.a) str-=1; if(keys.d) str+=1;
  if(keys.ArrowLeft) turn-=1; if(keys.ArrowRight) turn+=1;
  fwd-=jl.y; str+=jl.x; turn+=jr.x;
  cam.angle-=turn*0.038;
  cam.pitch-=jr.y*0.025; cam.pitch=Math.max(-MAX_PITCH,Math.min(MAX_PITCH,cam.pitch));
  const sp=0.072*(performance.now()<speedBoostUntil?1.7:1);
  const tVX=(Math.sin(cam.angle)*fwd-Math.cos(cam.angle)*str)*sp;
  const tVZ=(Math.cos(cam.angle)*fwd+Math.sin(cam.angle)*str)*sp;
  velX+=(tVX-velX)*0.22; velZ+=(tVZ-velZ)*0.22;
  const margin=0.3;
  if(!solidAt(map,cam.x+velX+Math.sign(velX)*margin,cam.z)) cam.x+=velX; else velX=0;
  if(!solidAt(map,cam.x,cam.z+velZ+Math.sign(velZ)*margin)) cam.z+=velZ; else velZ=0;
  const speed=Math.hypot(velX,velZ);
  // First-step gate — the black hunter stays dormant until the player actually moves this level.
  if(!hasMovedThisLevel && speed>0.012 && performance.now()>=inputGraceUntil) hasMovedThisLevel=true;
  if(speed>0.005){
    cam.y=1.65+Math.sin(performance.now()*0.008)*0.025*Math.min(1,speed/0.06);
    footstepTimer--;
    if(footstepTimer<=0){
      if(currentLevel===1) sfx.stoneStep();
      else if(currentLevel===2) sfx.metalStep();
      else sfx.footstep();
      footstepTimer=20+Math.floor(Math.random()*10);
    }
  }
}

