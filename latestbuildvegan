  if(hp<=0) die();
}

// Pick a manifest spot: prefer a far corridor-end the player is looking down, else one of the
// four outer corners, else the darkest nearby open cell — and only if it's genuinely dark there.
function blackManifest(){
  const ld=levelData[currentLevel]; if(!ld||!ld.openCells.length) return false;
  const fwdX=Math.sin(cam.angle), fwdZ=Math.cos(cam.angle);
  const corners=[[3,3],[GRID-4,3],[3,GRID-4],[GRID-4,GRID-4]];
  const dGate = currentLevel===3 ? -1 : null; // L3 (fluorescent) has no "dark enough" cells -> drop the gate there
  // If the player is in/near an outer corner, ~50% of the time put him in one of the two VISIBLE
  // corners. The two visible ones share an edge with yours; the diagonal-opposite (shares no edge)
  // is the one you can't see, so it's excluded geometrically. (Attack logic downstream unchanged.)
  let nearCorner=null;
  for(const cc of corners){ if(Math.hypot(cc[0]+0.5-cam.x,cc[1]+0.5-cam.z)<6.5){ nearCorner=cc; break; } } // covers the 6x6 corner room
  if(nearCorner && Math.random()<0.5){
    const adj=corners.filter(cc=> cc!==nearCorner && (cc[0]===nearCorner[0] || cc[1]===nearCorner[1])); // the two adjacent (visible) corners
    const g = dGate!==null ? dGate : 0.35;
    const pick=adj.filter(cc=>{
      const ddx=cc[0]+0.5-cam.x, ddz=cc[1]+0.5-cam.z, dd=Math.hypot(ddx,ddz)||1;
      const dt=(ddx*fwdX+ddz*fwdZ)/dd;            // roughly in front so the player can see/stare at it
      return dt>0 && darknessAt(cc[0]+0.5,cc[1]+0.5)>g;
    });
    const choice = pick.length ? pick[(Math.random()*pick.length)|0] : null;
    if(choice){ blackFig.moveTo(choice[0]+0.5,choice[1]+0.5); blackFig.state='watching'; blackFig.targetVis=BLACK_MAX_OPACITY; return true; }
  }
  // corridor-end in view?
  let corridor=0;
  for(let d=3; d<14; d++){ if(blackCellOpen(cam.x+fwdX*d, cam.z+fwdZ*d)) corridor=d; else break; }
  if(corridor>=6){
    const cx=cam.x+fwdX*corridor, cz=cam.z+fwdZ*corridor;
    if(darknessAt(cx,cz)>(dGate!==null?dGate:0.45)){ blackFig.moveTo(cx,cz); blackFig.state='watching'; blackFig.targetVis=BLACK_MAX_OPACITY; return true; }
  }
  // one of the four outer corners, if dark and not too close
  const openCorners=corners.filter(c=>blackCellOpen(c[0]+0.5,c[1]+0.5)
    && Math.hypot(c[0]+0.5-cam.x,c[1]+0.5-cam.z)>6
    && darknessAt(c[0]+0.5,c[1]+0.5)>(dGate!==null?dGate:0.5));
  if(openCorners.length && Math.random()<0.6){
    const c=openCorners[(Math.random()*openCorners.length)|0];
    blackFig.moveTo(c[0]+0.5,c[1]+0.5); blackFig.state='watching'; blackFig.targetVis=BLACK_MAX_OPACITY; return true;
  }
  // darkest open cell within mid range
  let best=null,bestDark=0;
  for(let i=0;i<18;i++){
    const c=ld.openCells[(Math.random()*ld.openCells.length)|0];
    const dist=Math.hypot(c[0]+0.5-cam.x,c[1]+0.5-cam.z);
    if(dist<3||dist>10) continue;
    const dk=darknessAt(c[0]+0.5,c[1]+0.5);
    if(dk>bestDark){ bestDark=dk; best=c; }
  }
  if(best && bestDark>(dGate!==null?dGate:0.55)){ blackFig.moveTo(best[0]+0.5,best[1]+0.5); blackFig.state='watching'; blackFig.targetVis=BLACK_MAX_OPACITY*0.85; return true; }
  return false;
}

function updateBlackFig(){
  if(!blackFig.sprite || blackFig.lv!==currentLevel) return;
  if(!hasMovedThisLevel){ blackFig.hide(); return; } // dormant until first step
  if(blackCooldown>0) blackCooldown--;

  const dx=blackFig.x-cam.x, dz=blackFig.z-cam.z;
  const dist=Math.hypot(dx,dz);
  const fwdX=Math.sin(cam.angle), fwdZ=Math.cos(cam.angle);
  const dot=(dx*fwdX+dz*fwdZ)/Math.max(0.1,dist);
  const lookingAt = dot>0.86 && dist<16; // eyes roughly on him

  if(blackFig.state==='hidden'){
    stareFrames=0;
    if(blackCooldown<=0){
      // manifestation roll. L3 (lit backrooms) gets a higher floor so he actually appears there;
      // L1/L2 stay biased to when the player is somewhere dark.
      const here=darknessAtPlayerCached();
      const chance=(currentLevel===3 ? 0.0045 : 0.0012) + here*0.0016;
      if(Math.random()<chance) blackManifest();
    }
    return;
  }

  // state === 'watching' — stationary. Ease opacity toward target (feathered fade in/out).
  blackFig.setVis(blackFig.vis + (blackFig.targetVis-blackFig.vis)*0.08);
  const litLevel = currentLevel===3; // backrooms are lit -> don't require darkness for strike/persistence

  // A) proximity -> strike (dark areas on L1/L2; anywhere on L3 since it's lit)
  if(dist<STRIKE_RANGE && (litLevel || darknessAtPlayerCached()>0.4)){ blackStrike(); return; }

  // B) sustained stare on an already-manifested watcher -> blink to a foot away, then strike
  if(lookingAt){
    stareFrames++;
    if(stareFrames>=STARE_FRAMES){
      // teleport blink (no travel): appear ~1 ft in front of the player
      const bx=cam.x+fwdX*0.9, bz=cam.z+fwdZ*0.9;
      if(blackCellOpen(bx,bz)) blackFig.moveTo(bx,bz); else blackFig.moveTo(cam.x,cam.z);
      blackFig.setVis(BLACK_MAX_OPACITY);
      blackStrike();
      return;
    }
  } else {
    stareFrames=Math.max(0,stareFrames-2); // looking away bleeds the timer down
    // dissolve only if the player has truly left it behind. On L3 don't use the darkness test
    // (everything is lit), so he persists long enough for you to turn and stare.
    if(dist>14 || (!litLevel && darknessAt(blackFig.x,blackFig.z)<0.3)){
      blackFig.targetVis=0; if(blackFig.vis<0.03){ blackFig.hide(); blackCooldown=Math.max(blackCooldown,300); }
    }
  }
}

// When a light flickers off, the watcher sometimes flickers into that spot, then is gone.
function blackFlickerIn(lx,lz){
  if(!blackFig.sprite || blackFig.lv!==currentLevel) return;
  if(!hasMovedThisLevel || blackCooldown>0 || blackFig.state!=='hidden') return;
  if(Math.random()<0.5) return; // only sometimes
  const d=Math.hypot(lx-cam.x,lz-cam.z); if(d<3||d>13) return;
  blackFig.moveTo(lx,lz);
  blackFig.state='watching'; blackFig.setVis(BLACK_MAX_OPACITY); blackFig.targetVis=0; // appears then fades as light returns
  setTimeout(()=>{ if(blackFig.state==='watching'&&blackFig.vis<0.05) blackFig.hide(); }, 900);
}

