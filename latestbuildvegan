let AC=null, master=null, ambientNode=null, sfxGain=null, audioStarted=false;
function initAudio(){
  if(AC) return;
  try{ AC=new(window.AudioContext||window.webkitAudioContext)(); }catch(e){ return; }
  master=AC.createGain(); master.gain.value=0.82; master.connect(AC.destination);
  sfxGain=AC.createGain(); sfxGain.gain.value=0.75; sfxGain.connect(master);
}
function unlockAudio(){ if(!AC) initAudio(); if(AC&&AC.state==='suspended') AC.resume(); }

let currentAmbientGain=null;
function startAmbient(level){
  if(!AC) return;
  // Fade out old ambient
  if(currentAmbientGain){
    const g=currentAmbientGain;
    g.gain.cancelScheduledValues(AC.currentTime);
    g.gain.setValueAtTime(g.gain.value,AC.currentTime);
    g.gain.linearRampToValueAtTime(0,AC.currentTime+1.2);
  }
  const newGain=AC.createGain(); newGain.gain.value=0; newGain.connect(master);
  currentAmbientGain=newGain;

  const makeOsc=(type,freq,vol,dest)=>{
    const o=AC.createOscillator(),g=AC.createGain();
    o.type=type; o.frequency.value=freq; g.gain.value=vol;
    o.connect(g); g.connect(dest); o.start(); return o;
  };
  const makeFilt=(type,freq,src,dest)=>{
    const f=AC.createBiquadFilter(); f.type=type; f.frequency.value=freq;
    src.connect(f); f.connect(dest); return f;
  };

  if(level===1){
    // Stone pyramid: low sub + warm wind pad
    const sub=makeOsc('sine',28,0,newGain); sub.frequency.value=28;
    const sg=AC.createGain(); sg.gain.value=0.11; sub.connect(sg); sg.connect(newGain);
    const pad=makeOsc('triangle',82,0.05,newGain);
    const lfo=makeOsc('sine',0.018,0,null);
    const lg=AC.createGain(); lg.gain.value=0.032;
    lfo.connect(lg); lg.connect(AC.createGain()); // just run the lfo
    makeOsc('sawtooth',55,0,null); // wind tone through filter
    const wOsc=AC.createOscillator(); wOsc.type='sawtooth'; wOsc.frequency.value=55; wOsc.start();
    const wf=AC.createBiquadFilter(); wf.type='lowpass'; wf.frequency.value=110;
    const wg=AC.createGain(); wg.gain.value=0.035;
    wOsc.connect(wf); wf.connect(wg); wg.connect(newGain);
  } else if(level===2){
    // Industrial: 60hz hum + mechanical drone
    const humOsc=AC.createOscillator(); humOsc.type='sawtooth'; humOsc.frequency.value=60; humOsc.start();
    const hf=AC.createBiquadFilter(); hf.type='lowpass'; hf.frequency.value=180;
    const hg=AC.createGain(); hg.gain.value=0.022;
    humOsc.connect(hf); hf.connect(hg); hg.connect(newGain);
    const drone=AC.createOscillator(); drone.type='sine'; drone.frequency.value=38;
    const dg=AC.createGain(); dg.gain.value=0.09; drone.connect(dg); dg.connect(newGain); drone.start();
    const high=AC.createOscillator(); high.type='triangle'; high.frequency.value=220;
    const highG=AC.createGain(); highG.gain.value=0.016; high.connect(highG); highG.connect(newGain); high.start();
  } else {
    // Backrooms: fluorescent buzz + deep drone + choir breath
    const humOsc=AC.createOscillator(); humOsc.type='sawtooth'; humOsc.frequency.value=60; humOsc.start();
    const hf=AC.createBiquadFilter(); hf.type='lowpass'; hf.frequency.value=200;
    const hg=AC.createGain(); hg.gain.value=0.017;
    humOsc.connect(hf); hf.connect(hg); hg.connect(newGain);
    const drone=AC.createOscillator(); drone.type='sine'; drone.frequency.value=48;
    const dg=AC.createGain(); dg.gain.value=0.065; drone.connect(dg); dg.connect(newGain); drone.start();
    const choir=AC.createOscillator(); choir.type='triangle'; choir.frequency.value=110;
    const cLFO=AC.createOscillator(); cLFO.frequency.value=0.04; cLFO.start();
    const cLG=AC.createGain(); cLG.gain.value=0.038;
    const cG=AC.createGain(); cG.gain.value=0.0;
    cLFO.connect(cLG); cLG.connect(cG.gain); choir.connect(cG); cG.connect(newGain); choir.start();
  }
  newGain.gain.linearRampToValueAtTime(0.82, AC.currentTime+3.5);
}

function tone(f,type,dur,vol,slide=0){
  if(!AC) return;
  const o=AC.createOscillator(),g=AC.createGain();
  o.type=type; o.frequency.setValueAtTime(f,AC.currentTime);
  if(slide) o.frequency.exponentialRampToValueAtTime(Math.max(1,f+slide),AC.currentTime+dur);
  g.gain.setValueAtTime(vol,AC.currentTime);
  g.gain.exponentialRampToValueAtTime(0.001,AC.currentTime+dur);
  o.connect(g); g.connect(sfxGain); o.start(); o.stop(AC.currentTime+dur);
}
function noise(dur,vol,freq){
  if(!AC) return;
  const len=Math.floor(AC.sampleRate*dur),buf=AC.createBuffer(1,len,AC.sampleRate),d=buf.getChannelData(0);
  for(let i=0;i<len;i++) d[i]=(Math.random()*2-1)*(1-i/len);
  const src=AC.createBufferSource(); src.buffer=buf;
  const f=AC.createBiquadFilter(); f.type='lowpass'; f.frequency.value=freq||1000;
  const g=AC.createGain(); g.gain.value=vol;
  src.connect(f); f.connect(g); g.connect(sfxGain); src.start();
}
